<div class="row">
  <div class="col-md-8">
    <hr class="my-4" />

    <h4>Comments</h4>

    <% if (commentError) { %>
    <div class="alert alert-danger"><%= commentError %></div>
    <% } %>

    <% if (currentUser) { %>

    <!-- create comment -->
    <form
      id="comment-form"
      action="/posts/<%= post.slug %>/comments"
      class="mb-4"
      method="post"
    >
      <div class="mb-3">
        <textarea
          name="message"
          class="form-control"
          rows="3"
          placeholder="Write your comment here..."
        ></textarea>
      </div>
      <div class="d-flex justify-content-end">
        <button
          type="submit"
          class="btn btn-sm btn-primary"
        >
          Send
        </button>
      </div>
    </form>

    <% } else { %>
    <p class="alert alert-info">Please <a href="/login" class="mx-1">log in</a> to post a comment.</p>
    <% } %>

    <div id="commentsBox">
      <div>
        <% if(comments.length === 0) { %>
        <p class="text-muted">No comments yet. Be the first to comment!</p>
        <% } %>
      </div>

      <% comments.forEach(comment => { %>
      <div id="comment-box-<%= comment._id %>" class="">
        <!-- normal view -->
        <div id="comment-view-<%= comment._id %>" class="d-flex border rounded p-3 mb-3">
            <div class="flex-grow-1">
                <strong><%= comment.username || 'Anonymous' %></strong>
                <small class="text-muted d-block"><%= comment.createdAt.toLocaleString() %></small>
                <p class="mt-3"><%= comment.message %></p>
            </div>

            <!-- show action buttons only for comment owner -->
             <% if(currentUser?._id && comment.userId?.toString() && (currentUser._id === comment.userId.toString())){ %>
                  <div class="d-flex gap-2 flex-nowrap align-self-start ms-2">
                      <button
                        class="btn btn-sm btn-outline-secondary"
                        onclick="showEditForm('<%= comment._id %>')"
                      >
                        Edit
                      </button>
                      <form
                        action="/posts/<%= post.slug %>/comments/<%= comment._id %>/delete"
                        class="d-inline"
                        method="post"
                        onsubmit="return confirm('Are you sure you want to delete this comment?');"
                      >
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          Delete
                        </button>
                      </form>
                  </div>
              <% } %>
        </div>

        <!-- edit view -->
        <form
          id="comment-edit-<%= comment._id %>"
          action=""
          class="d-none mb-4"
          method="post"
        >
          <div class="mb-3">
            <textarea
              name="message"
              class="form-control"
              rows="3"
            ><%= comment.message %></textarea>
          </div>
          <div class="d-flex justify-content-end gap-2">
           <button
              type="button"
              class="btn btn-sm btn-outline-secondary"
              onclick="hideEditForm('<%= comment._id %>')"
            >
              Cancle
            </button>
            <button
              type="submit"
              class="btn btn-sm btn-primary"
            >
              Save
            </button>
          </div>
        </form>
        
      </div>
      <% }); %>
    </div>

  </div>

  <div class="col-md-4"></div>

</div>
