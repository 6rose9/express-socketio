<div class="row">
  <div class="col-md-8">
    <hr class="my-4" />

    <h4>Comments</h4>

    <% if (commentError) { %>
    <div class="alert alert-danger"><%= commentError %></div>
    <% } %>

    <form
      id="comment-form"
      action="/posts/<%= post.slug %>/comments"
      method="post"
    >
      <div class="mb-3">
        <input
          type="text"
          name="name"
          class="form-control"
          placeholder="Your name"
        />
      </div>

      <div class="mb-3">
        <textarea
          name="message"
          class="form-control"
          rows="3"
          placeholder="Write your comment here..."
        ></textarea>
      </div>
      <div class="d-flex justify-content-end">
        <button
          type="submit"
          class="btn btn-sm btn-primary"
        >
          Submit
        </button>
      </div>
    </form>

    <div id="commentsBox">
      <div>
        <% if(comments.length === 0) { %>
        <p class="text-muted">No comments yet. Be the first to comment!</p>
        <% } %>
      </div>

      <% comments.forEach(comment => { %>
      <div class="border-bottom py-3">
        <strong><%= comment.name %></strong>
        <small class="text-muted d-block"><%= comment.createdAt.toLocaleString() %></small>
        <p class="mt-3"><%= comment.message %></p>
      </div>
      <% }); %>
    </div>

  </div>

  <div class="col-md-4"></div>

</div>
